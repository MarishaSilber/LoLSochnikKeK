DATABASE_URL=postgresql+psycopg2://vuzhub_user:vuzhub_pass123@db:5432/vuzhub_db
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
DEBUG=false

YANDEX_API_KEY=replace-with-yandex-api-key
YANDEX_FOLDER_ID=replace-with-yandex-folder-id
YANDEX_MODEL_URI=

SWAGGER_USERNAME=replace-with-swagger-username
SWAGGER_PASSWORD=replace-with-swagger-password

BOOTSTRAP_ADMIN_EMAIL=replace-with-bootstrap-admin-email
BOOTSTRAP_ADMIN_PASSWORD=replace-with-bootstrap-admin-password

TERMS_VERSION=2026-04-09
PRIVACY_POLICY_VERSION=2026-04-09
ACCESS_TOKEN_TTL_SECONDS=86400
REGISTER_VERIFICATION_TTL_SECONDS=86400
PASSWORD_CHANGE_CONFIRM_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=1800

POSTBOX_SMTP_HOST=postbox.cloud.yandex.net
POSTBOX_SMTP_PORT=587
POSTBOX_SMTP_USERNAME=replace-with-postbox-smtp-username
POSTBOX_SMTP_PASSWORD=replace-with-postbox-smtp-password
POSTBOX_FROM_EMAIL=replace-with-verified-postbox-email
POSTBOX_FROM_NAME=VuzHub
FRONTEND_URL=http://localhost:5173
